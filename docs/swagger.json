{
    "swagger": "2.0",
    "info": {
        "description": "Pinn Server API for distributed task execution and model building.",
        "title": "Pinn API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Returns the health status of the application and its dependencies",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Check service health",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.HealthResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/domain.HealthResponse"
                        }
                    }
                }
            }
        },
        "/model": {
            "get": {
                "description": "Returns a list of all registered models",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "models"
                ],
                "summary": "List all models",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/domain.Model"
                            }
                        }
                    }
                }
            },
            "put": {
                "description": "Updates the container image for an existing model",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "models"
                ],
                "summary": "Update model image",
                "parameters": [
                    {
                        "description": "Update Model Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.UpdateModelRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Model updated",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid JSON",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Creates a new model entry with an existing container image",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "models"
                ],
                "summary": "Register a new model",
                "parameters": [
                    {
                        "description": "Create Model Request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.CreateModelRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/domain.Model"
                        }
                    },
                    "400": {
                        "description": "Invalid JSON or missing fields",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/model/build": {
            "put": {
                "description": "Accepts multipart/form-data to rebuild an existing model image",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "models"
                ],
                "summary": "Update and rebuild model from archive",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Model metadata (JSON)",
                        "name": "model",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "Tar.gz archive with artifacts",
                        "name": "artifacts",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "BUILD SUCCESSFUL",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Accepts multipart/form-data to build a new model image",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "models"
                ],
                "summary": "Build new model from archive",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Model metadata (JSON)",
                        "name": "model",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "Tar.gz archive with artifacts",
                        "name": "artifacts",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "BUILD SUCCESSFUL",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/model/{id}": {
            "delete": {
                "description": "Removes a model from the system and its associated container image",
                "tags": [
                    "models"
                ],
                "summary": "Delete a model",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Model ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Model deleted",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Missing or invalid ID",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/stats": {
            "get": {
                "description": "Returns CPU utilization and available memory of the host",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Get host resources statistics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.StatsResponse"
                        }
                    }
                }
            }
        },
        "/task/run": {
            "post": {
                "description": "Accepts multipart/form-data with task metadata and optional input file",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Create and run a new task",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Task metadata (JSON)",
                        "name": "task",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "Input file for the task",
                        "name": "file",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Task accepted",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or missing fields",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/task/{id}/status": {
            "get": {
                "description": "Returns the current status and metadata of a task",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Get task status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Task UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.TaskStatusResponse"
                        }
                    },
                    "404": {
                        "description": "Task not found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/task/{id}/stop": {
            "post": {
                "description": "Sends a stop signal to a running container task",
                "tags": [
                    "tasks"
                ],
                "summary": "Stop a running task",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Task UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Stop timeout (seconds or duration string)",
                        "name": "timeout",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Task stopped",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Invalid ID or timeout format",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.CreateModelRequest": {
            "type": "object",
            "properties": {
                "container_image": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                }
            }
        },
        "domain.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string"
                }
            }
        },
        "domain.Model": {
            "type": "object",
            "properties": {
                "containerImage": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "updatedAt": {
                    "type": "string"
                }
            }
        },
        "domain.StatsResponse": {
            "type": "object",
            "properties": {
                "available_memory_bytes": {
                    "type": "integer"
                },
                "cpu_utilization": {
                    "type": "number"
                }
            }
        },
        "domain.TaskStatusResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "err_log": {
                    "type": "string"
                },
                "finished_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "result_path": {
                    "type": "string"
                },
                "scheduled_at": {
                    "type": "string"
                },
                "started_at": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "domain.UpdateModelRequest": {
            "type": "object",
            "properties": {
                "container_image": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                }
            }
        }
    }
}